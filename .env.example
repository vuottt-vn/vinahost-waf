# Environment Configuration for WAF

# ============================================
# Database Configuration
# ============================================
# SQLite database path (inside container)
DB_PATH=/app/data/waf.db

# ============================================
# Server Ports
# ============================================
# WAF Proxy port (traffic protection)
PROXY_PORT=8080

# WAF API port (management backend)
API_PORT=3001

# Frontend port (dashboard)
FRONTEND_PORT=5173

# ============================================
# JWT Configuration
# ============================================
# CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiry (minutes)
JWT_ACCESS_EXPIRY=15

# Refresh token expiry (hours) - 168 = 7 days
JWT_REFRESH_EXPIRY=168

# ============================================
# WAF Configuration
# ============================================
# WAF Mode: on, detection_only, off
WAF_MODE=on

# Request body limit (bytes) - 128KB
WAF_REQ_BODY_LIMIT=131072

# Response body limit (bytes) - 128KB
WAF_RES_BODY_LIMIT=131072

# ============================================
# OWASP CRS Configuration
# ============================================
# Enable OWASP Core Rule Set
WAF_CRS_ENABLED=false

# CRS rules path (inside container)
WAF_CRS_PATH=/app/configs/crs

# ============================================
# Rate Limiting Configuration
# ============================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# JS Challenge Configuration
# ============================================
# Enable JS challenge for suspicious requests
CHALLENGE_ENABLED=true

# Anomaly score threshold for challenge
CHALLENGE_THRESHOLD=5

# Challenge token TTL (minutes)
CHALLENGE_TOKEN_TTL=30

# Challenge difficulty (1-5)
CHALLENGE_DIFFICULTY=3

# ============================================
# Frontend Configuration
# ============================================
# API URL for frontend
VITE_API_URL=http://localhost:3001/api

# ============================================
# Nginx Configuration (Optional)
# ============================================
# HTTP port
NGINX_HTTP_PORT=80

# HTTPS port
NGINX_HTTPS_PORT=443
